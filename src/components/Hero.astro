---
import { site } from "../site.config";

const resumeHref = site.resumePath;
---

<section id="hero" class="hero" aria-labelledby="hero-heading">
	<div id="hero-system-map" class="hero-scene" aria-hidden="true"></div>
	<div class="hero-overlay" aria-hidden="true"></div>
	<div class="hero-visual">
		<div class="hero-frame" data-hero-entrance style="--hero-delay: 80ms">
			<img
				src="/images/headshot.JPG"
				alt="André Ribeiro"
				width="280"
				height="280"
				fetchpriority="high"
			/>
		</div>
	</div>
	<div class="hero-copy">
		<p class="hero-role" data-hero-entrance style="--hero-delay: 160ms">{site.title}</p>
		<h1 id="hero-heading" data-hero-entrance style="--hero-delay: 260ms">
			{site.name}
		</h1>
		<p class="hero-tagline" data-hero-entrance style="--hero-delay: 380ms">
			{site.tagline}
		</p>
		<ul class="ctas" data-hero-entrance style="--hero-delay: 560ms">
			<li>
				<a class="primary" href={site.linkedin} target="_blank" rel="noopener noreferrer"
					>LinkedIn</a
				>
			</li>
			<li>
				<a href={site.github} target="_blank" rel="noopener noreferrer">GitHub</a>
			</li>
			<li>
				<a href={`mailto:${site.email}`}>Email</a>
			</li>
			<li>
				<a href={resumeHref}>Résumé PDF</a>
			</li>
			<li>
				<a href="#work">View work</a>
			</li>
		</ul>
	</div>

	<script>
		(() => {
			const hero = document.getElementById("hero");
			const mount = document.getElementById("hero-system-map");
			if (!hero || !(mount instanceof HTMLElement)) return;

			const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

			let cleanup = () => {};
			(async () => {
				try {
					const { createHeroSystemMap } = await import("../scripts/hero-system-map");
					const map = createHeroSystemMap({ container: mount, reducedMotion: prefersReduced });
					map.resize();

					const observer = new IntersectionObserver(
						([entry]) => {
							if (entry?.isIntersecting) map.start();
							else map.stop();
						},
						{ threshold: 0.1 },
					);
					observer.observe(hero);

					const onResize = () => map.resize();
					const onPageHide = () => map.dispose();
					window.addEventListener("resize", onResize);
					window.addEventListener("pagehide", onPageHide, { once: true });

					map.start();

					cleanup = () => {
						observer.disconnect();
						window.removeEventListener("resize", onResize);
						map.dispose();
					};
				} catch {
					hero.classList.add("hero-fallback");
				}
			})();

			window.addEventListener("pagehide", () => cleanup(), { once: true });
		})();
	</script>
</section>
