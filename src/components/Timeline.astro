---
import { getCollection } from "astro:content";
import RoleCard from "./RoleCard.astro";

const roles = (await getCollection("roles")).sort(
	(a, b) => a.data.order - b.data.order,
);
---

<section id="work" aria-labelledby="work-heading">
	<div class="work-top">
		<h2 id="work-heading">Work</h2>
		<div id="work-now" class="work-now" aria-live="polite">
			<div class="work-now-label">Highlights</div>
			<div class="work-now-text">Expand a role to preview key outcomes.</div>
		</div>
	</div>
	<div class="timeline" id="timeline">
		<div class="pipeline-track" aria-hidden="true">
			<div class="pipeline-fill"></div>
		</div>
		{roles.map((entry) => (
			<div class="timeline-entry">
				<div class="pipeline-node" aria-hidden="true"></div>
				<RoleCard entry={entry} />
			</div>
		))}
	</div>

	<script>
		(() => {
			const now = document.getElementById("work-now");
			if (!now) return;
			const textEl = now.querySelector<HTMLElement>(".work-now-text");
			if (!textEl) return;
			const details = Array.from(
				document.querySelectorAll<HTMLDetailsElement>("#work details")
			);

			const timelineEl = document.getElementById("timeline");
			const fill = document.querySelector<HTMLElement>(".pipeline-fill");
			const nodes = Array.from(
				document.querySelectorAll<HTMLElement>(".pipeline-node")
			);

			const updatePipeline = () => {
				if (!timelineEl || !fill) return;

				const trigger = window.innerHeight * 0.65;
				const rect = timelineEl.getBoundingClientRect();
				const progress = Math.max(
					0,
					Math.min(1, (trigger - rect.top) / rect.height),
				);
				fill.style.transform = `scaleY(${progress})`;

				let lastActive: HTMLElement | null = null;
				for (const node of nodes) {
					const nodeRect = node.getBoundingClientRect();
					if (nodeRect.top < trigger) {
						node.classList.add("active");
						node.classList.remove("pulse");
						lastActive = node;
					} else {
						node.classList.remove("active");
						node.classList.remove("pulse");
					}
				}

				if (lastActive) lastActive.classList.add("pulse");
			};

			const updateFromDetails = (d: HTMLDetailsElement) => {
				const summary = d.querySelector<HTMLElement>("summary");
				if (!summary) return;

				const company = summary.querySelector(".company")?.textContent?.trim() ?? "";
				const title = summary.querySelector(".title")?.textContent?.trim() ?? "";
				const meta = summary.querySelector(".meta")?.textContent?.trim() ?? "";
				const hook = summary.querySelector(".hook")?.textContent?.trim() ?? "";
				const metric = d.querySelector(".metrics li")?.textContent?.trim() ?? "";

				const heading = [company, title].filter(Boolean).join(" — ");
				const outcome = metric || hook || meta;

				if (heading || outcome) {
					now.classList.add("is-active");
					textEl.textContent = [heading, outcome].filter(Boolean).join(": ");
				}
			};

			const reset = () => {
				now.classList.remove("is-active");
				textEl.textContent = "Expand a role to preview key outcomes.";
			};

			// Handle both single and multi-open details.
			details.forEach((d) => {
				d.addEventListener("toggle", () => {
					if (d.open) updateFromDetails(d);
					else {
						// If nothing is open anymore, reset.
						const anyOpen = details.some((x) => x.open);
						if (!anyOpen) reset();
					}

					// Recompute pipeline after layout changes (details expand/collapse).
					requestAnimationFrame(() => updatePipeline());
				});
			});

			let ticking = false;
			const onScroll = () => {
				if (ticking) return;
				ticking = true;
				requestAnimationFrame(() => {
					updatePipeline();
					ticking = false;
				});
			};

			window.addEventListener("scroll", onScroll, { passive: true });
			window.addEventListener("resize", onScroll, { passive: true });
			updatePipeline();
		})();
	</script>
</section>
